{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "type": "object",
  "required": ["id", "firstName", "lastName", "email", "username"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "firstName": {
      "type": "string",
      "minLength": 1
    },
    "lastName": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "username": {
      "type": "string",
      "minLength": 1
    },
    "phone": {
      "type": ["string", "null"]
    },
    "jobTitle": {
      "type": ["string", "null"]
    },
    "department": {
      "type": ["string", "null"]
    },
    "status": {
      "type": ["string", "null"],
      "enum": ["ACTIVE", "INACTIVE", "PENDING", null]
    }
  },
  "additionalProperties": true
}
