<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SmokeSuite" verbose="1" parallel="methods" thread-count="4">
    <listeners>
        <listener class-name="com.automation.api.listeners.TestListener"/>
        <listener class-name="com.automation.api.listeners.RetryListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.automation.api.tests"/>
        </packages>
    </test>
</suite>
